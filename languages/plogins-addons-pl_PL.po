#: templates/admin/product-data-panel.php:68
#: templates/admin/product-data-panel.php:113
msgid "Maximum character length"
msgstr "Maksymalna liczba znaków"

#: templates/admin/product-data-panel.php:72
#: templates/admin/product-data-panel.php:117
msgid "Required"
msgstr "Wymagane"

#: templates/admin/product-data-panel.php:74
#: templates/admin/product-data-panel.php:119
msgid "Remove"
msgstr "Usuń"

#: templates/admin/product-data-panel.php:77
#: templates/admin/product-data-panel.php:122
msgid "Select options, one per line: Label | price"
msgstr "Opcje listy, jedna w wierszu: Etykieta | cena"

#: templates/admin/product-data-panel.php:77
#: templates/admin/product-data-panel.php:122
msgid "Choices for the Select type"
msgstr "Opcje dla typu Lista"

#: templates/admin/product-data-panel.php:78
#: templates/admin/product-data-panel.php:123
msgid ""
"Only used for the \"Select\" type. One choice per line as \"Label | price\","
" e.g. \"Standard | 0\" and \"Premium | 9.99\". Omit the price for a free "
"choice."
msgstr ""
"Używane tylko dla typu „Lista”. Jedna opcja w wierszu w formacie „Etykieta |"
" cena”, np. „Standard | 0” i „Premium | 9,99”. Pomiń cenę, jeśli wybór ma "
"być bezpłatny."

#: templates/admin/product-data-panel.php:97
msgid "Add option"
msgstr "Dodaj opcję"
